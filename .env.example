# Copy to .env for local use, or set these in your host's dashboard.
# NEVER commit real secrets.

# Port the server listens on (hosts usually set this automatically).
PORT=3000

# Sign-in token secret. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string

# Admin account seeded on first boot.
ADMIN_EMAIL=admin@ithr360.com
ADMIN_PASSWORD=change-me-strong-password

# Where the JSON data store is written. On a host, point this at a
# persistent disk (e.g. /var/data) so learner data survives restarts.
DATA_DIR=

# AI Tutor model provider (optional). Set ONE to enable live tutoring;
# leave both empty to run the built-in demo tutor.
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Premium AI-tutor voice (optional). Set ONE provider to upgrade the read-aloud
# voice; otherwise the tutor uses the browser's built-in voice (free).
# OpenAI TTS:
# OPENAI_API_KEY=sk-...
# OPENAI_TTS_VOICE=alloy            # alloy | echo | fable | onyx | nova | shimmer
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# ElevenLabs (takes priority if set):
# ELEVENLABS_API_KEY=...
# ELEVENLABS_VOICE_ID=...
# ELEVENLABS_MODEL=eleven_multilingual_v2
