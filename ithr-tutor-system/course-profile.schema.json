{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ithr360.com/schemas/course-profile.schema.json",
  "title": "ITHR AI Tutor — Course Profile",
  "description": "Defines a single course-specific AI tutor. Supplying one object instantiates one tutor.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "courseName", "tutorName", "level", "tier", "targetLearnerPersona",
    "syllabusOutline", "keyConcepts", "learningObjectives",
    "assessmentCriteria", "realWorldDomain", "inScopeTopics",
    "outOfScopeTopics", "defaultLanguage", "escalation"
  ],
  "properties": {
    "courseId":   { "type": "integer", "description": "Internal course id (optional)." },
    "courseSlug": { "type": "string", "pattern": "^[a-z0-9-]+$", "description": "URL/lookup key." },
    "courseName": { "type": "string", "minLength": 3, "description": "Exact course title the tutor is bound to." },
    "tutorName":  { "type": "string", "minLength": 1, "description": "Friendly persona name, e.g. 'Aria'." },
    "institution": { "type": "string", "default": "ITHR Technologies Consulting LLC" },
    "level": { "type": "string", "enum": ["Beginner", "Intermediate", "Advanced"] },
    "tier": {
      "type": "string",
      "enum": ["Fundamentals", "Practitioner", "Specialist", "Expert", "Strategist"]
    },
    "targetLearnerPersona": { "type": "string", "minLength": 10, "description": "Who the learner is — background, goals, prior knowledge." },
    "prerequisites": { "type": "array", "items": { "type": "string" }, "default": [] },
    "syllabusOutline": {
      "type": "array", "minItems": 1, "items": { "type": "string" },
      "description": "Ordered module/topic titles. Defines the tutor's teaching scope."
    },
    "keyConcepts": {
      "type": "array", "minItems": 1, "items": { "type": "string" },
      "description": "The must-know ideas the tutor anchors on."
    },
    "learningObjectives": {
      "type": "array", "minItems": 1, "items": { "type": "string" },
      "description": "What the learner should be able to DO after the course."
    },
    "assessmentCriteria": { "type": "string", "description": "Exam format, question count, pass mark." },
    "realWorldDomain": { "type": "string", "description": "Domain used for applied examples." },
    "inScopeTopics": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "outOfScopeTopics": { "type": "array", "items": { "type": "string" } },
    "preserveTerms": {
      "type": "array", "items": { "type": "string" },
      "description": "Technical terms kept canonical across all languages."
    },
    "defaultLanguage": {
      "type": "string", "pattern": "^[a-z]{2,3}(-[A-Za-z0-9]+)?$",
      "description": "BCP-47 code, e.g. 'en'. Must be one of the supported languages."
    },
    "escalation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["humanInstructorContact", "conditions"],
      "properties": {
        "humanInstructorContact": { "type": "string", "description": "Email or queue for human handoff." },
        "conditions": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    }
  }
}
